# BiblioDrift Environment Configuration Example
# Copy this file to .env and customize for your environment

# Application Environment (development, production, testing)
APP_ENV=development

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
JWT_ALGORITHM=HS256

# Database Configuration
DATABASE_URL=sqlite:///instance/biblio.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Server Configuration
FLASK_HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=True

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=True
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=30

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE=logs/bibliodrift.log

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# LLM Configuration
PREFERRED_LLM=groq
OPENAI_MODEL=gpt-3.5-turbo
GROQ_MODEL=openai/gpt-oss-20b
GEMINI_MODEL=gemini-1.5-flash
DEFAULT_MAX_TOKENS=150
BOOK_NOTE_MAX_TOKENS=100
RECOMMENDATION_MAX_TOKENS=150

# Purchase Links Configuration
AMAZON_AFFILIATE_TAG=your_amazon_affiliate_tag
FLIPKART_AFFILIATE_ID=your_flipkart_affiliate_id
BARNES_NOBLE_AFFILIATE_ID=your_barnes_noble_affiliate_id
PURCHASE_LINKS_CACHE_TTL=3600

# Caching Configuration (if using caching features)
# CACHE_TYPE=simple
# REDIS_URL=redis://localhost:6379/0
# CACHE_MOOD_ANALYSIS_TTL=86400
# CACHE_RECOMMENDATIONS_TTL=3600
# CACHE_MOOD_TAGS_TTL=43200
# CACHE_CHAT_RESPONSE_TTL=1800
# CACHE_GOODREADS_TTL=604800
# CACHE_DEFAULT_TIMEOUT=3600