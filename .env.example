# BiblioDrift Environment Configuration

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here

# Database Configuration
DATABASE_URL=sqlite:///biblio.db

# AI Service Configuration
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# Google Books API
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Caching Configuration
CACHE_TYPE=simple  # Options: simple, redis, null
REDIS_URL=redis://localhost:6379/0

# Cache TTL Values (in seconds)
CACHE_MOOD_ANALYSIS_TTL=86400     # 24 hours
CACHE_RECOMMENDATIONS_TTL=3600    # 1 hour  
CACHE_MOOD_TAGS_TTL=43200         # 12 hours
CACHE_CHAT_RESPONSE_TTL=1800      # 30 minutes
CACHE_GOODREADS_TTL=604800        # 7 days
CACHE_DEFAULT_TIMEOUT=3600        # 1 hour

# Flask Configuration
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
PORT=5000

# Logging
LOG_LEVEL=INFO